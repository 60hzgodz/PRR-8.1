<Window x:Class="PRR_8.Password"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пароль" Height="450" Width="400">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="#FFBD08FF" Offset="0.5"/>
            <GradientStop Color="Black" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <TextBox x:Name="CodeTextBox"
    HorizontalAlignment="Center"
    Height="26"
    Margin="0,217,0,0"
    TextWrapping="Wrap"
    Text="Код из почты"
    VerticalAlignment="Top"
    Width="173"
    Foreground="White"
    BorderBrush="Black"
    Background="{x:Null}"
    GotFocus="CodeTextBox_GetFocus"
    LostFocus="CodeTextBox_LostFocus" FontSize="14"/>
        <Button x:Name="ConfirmButton"
            Content="Подтвердить"
            HorizontalAlignment="Center"
            Margin="0,341,0,0"
            VerticalAlignment="Top"
            Width="172"
            Height="30"
            Click="ConfirmButton_Click" Foreground="White" Background="{x:Null}" BorderBrush="{x:Null}" FontSize="20"/>
        <Image HorizontalAlignment="Center" Height="173" VerticalAlignment="Top" Width="330" Source="/8fbe90f7-0c11-40f7-9c7c-8de1376dc9e2.png"/>
        <Label Content="СКИ &quot;ИМПУЛЬС&quot;"
            HorizontalAlignment="Left" Margin="114,153,0,0"
            VerticalAlignment="Top" Height="56" Width="182" FontSize="20"
            FontFamily="Copperplate Gothic Bold"
            Foreground="White" Background="{x:Null}"/>

    </Grid>
</Window>