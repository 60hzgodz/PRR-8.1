<Window x:Class="PRR_8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PRR_8"
        Title="Авторизация" Height="450" Width="400">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Black"/>
                    <Setter Property="Background" Value="{x:Null}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="Black"/>
                    <Setter Property="Background" Value="{x:Null}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для PasswordBox: убираем подсветку -->
        <Style TargetType="PasswordBox">
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Black"/>
                    <Setter Property="Background" Value="{x:Null}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="Black"/>
                    <Setter Property="Background" Value="{x:Null}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для Button: убираем подсветку -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="20"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{x:Null}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{x:Null}"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black" Offset="0"/>
                <GradientStop Color="#FFB700FC" Offset="0.518"/>
                <GradientStop Color="Black" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Label Content="СКИ &quot;ИМПУЛЬС&quot;"
               HorizontalAlignment="Left" Margin="114,153,0,0"
               VerticalAlignment="Top" Height="56" Width="182" FontSize="20"
               FontFamily="Copperplate Gothic Bold"
               Foreground="White" Background="{x:Null}"/>

        <!-- Кнопка "Войти" -->
        <Button Content="Войти"
                HorizontalAlignment="Left"
                Margin="148,331,0,0"
                VerticalAlignment="Top"
                Width="90"
                Height="32"
                FontSize="20" Foreground="White" Click="Button_Click_1">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>

        <!-- Кнопка "Забыли пароль" -->
        <Button Content="Забыли пароль"
                HorizontalAlignment="Left" Margin="174,278,0,0"
                VerticalAlignment="Top" Width="125"
                Click="Button_Click" FontSize="16" Foreground="White"/>
        <PasswordBox x:Name="PasswordBox"
                     HorizontalAlignment="Left"
                     Margin="100,252,0,0" 
                     VerticalAlignment="Top" 
                     Width="199"
                     Height="21"
                     GotFocus="PasswordBox_GotFocus"
                     LostFocus="PasswordBox_LostFocus"/>
        <TextBox x:Name="LoginTextBox"
                 HorizontalAlignment="Left" 
                 Height="23"
                 Margin="100,214,0,0" 
                 TextWrapping="Wrap" 
                 Text="Логин или почта" 
                 VerticalAlignment="Top" 
                 Width="199"
                 Foreground="White"
                 GotFocus="LoginTextBox_GotFocus"
                 LostFocus="LoginTextBox_LostFocus"/>
        <Image HorizontalAlignment="Center" Height="173" VerticalAlignment="Top" Width="330" Source="/8fbe90f7-0c11-40f7-9c7c-8de1376dc9e2.png"/>
    </Grid>
</Window>