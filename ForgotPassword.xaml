<Window x:Class="PRR_8.ForgotPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Восстановление" Height="450" Width="400">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="Black" Offset="1"/>
            <GradientStop Color="#FFBD08FF" Offset="0.523"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <TextBox x:Name="LoginTextBox"
            HorizontalAlignment="Center"
            Height="24"
            Margin="0,214,0,0"
            TextWrapping="Wrap"
            Text="Логин или почта"
            VerticalAlignment="Top"
            Width="188"
            Foreground="White"
            BorderBrush="Black"
            Background="{x:Null}"
            GotFocus="LoginTextBox_GetFocus"
            LostFocus="LoginTextBox_LostFocus" FontSize="14"/>

        <Button x:Name="ResetButton"
            Content="Восстановить"
            HorizontalAlignment="Center"
            Margin="0,329,0,0"
            VerticalAlignment="Top"
            Width="172"
            Height="30"
            Click="Button_Click" Background="{x:Null}" Foreground="White" BorderBrush="{x:Null}" FontSize="20"/>
        <Label Content="СКИ &quot;ИМПУЛЬС&quot;"
            HorizontalAlignment="Left" Margin="114,153,0,0"
            VerticalAlignment="Top" Height="56" Width="182" FontSize="20"
            FontFamily="Copperplate Gothic Bold"
            Foreground="White" Background="{x:Null}"/>
        <Image HorizontalAlignment="Center" Height="173" VerticalAlignment="Top" Width="330" Source="/8fbe90f7-0c11-40f7-9c7c-8de1376dc9e2.png"/>
    </Grid>
</Window>