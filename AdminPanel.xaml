<Window x:Class="PRR_8.AdminPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PRR_8"
        mc:Ignorable="d"
        Title="AdminPanel" Height="500" Width="800">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FFBD08FF" Offset="0.507"/>
                <GradientStop Color="Black" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Menu VerticalAlignment ="Top" Foreground="White">
            <Menu.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black"/>
                    <GradientStop Color="#FFCA8DFF" Offset="0.54"/>
                    <GradientStop Color="Black" Offset="1"/>
                </LinearGradientBrush>
            </Menu.Background>
            <MenuItem Header = "Пользователи" x:Name="User" Foreground="White"  BorderBrush="Black" FontFamily="Times New Roman" FontSize="14" Click="MenuItem_Click" Background="{x:Null}">
            </MenuItem>
            <MenuItem Header = "Залы" x:Name="Halls" Foreground="White"  BorderBrush="Black" FontFamily="Times New Roman" FontSize="14" Click="MenuItem_Click" Background="{x:Null}">
            </MenuItem>
            <MenuItem Header = "Данные" x:Name="Data" Foreground="White"  BorderBrush="Black" FontFamily="Times New Roman" FontSize="14" Click="MenuItem_Click" Background="{x:Null}">
            </MenuItem>
            <MenuItem Header = "Отчёты" x:Name="Reports" Foreground="White"  BorderBrush="Black" FontFamily="Times New Roman" FontSize="14" Click="MenuItem_Click" Background="{x:Null}">
            </MenuItem>
            <MenuItem Header = "Мониторинг" x:Name="Monitoring" Foreground="White"  BorderBrush="Black" FontFamily="Times New Roman" FontSize="14" Click="MenuItem_Click" Background="{x:Null}">
            </MenuItem>
            <MenuItem Header = "Тренировки" x:Name="Coaching" Foreground="White"  BorderBrush="Black" FontFamily="Times New Roman" FontSize="14" Click="MenuItem_Click" Background="{x:Null}">
            </MenuItem>
            <MenuItem Header = "Обслуживание" x:Name="Service" Foreground="White"  BorderBrush="Black" FontFamily="Times New Roman" FontSize="14" Click="MenuItem_Click" Background="{x:Null}">
            </MenuItem>
            <MenuItem Header = "Абонементы" x:Name="Ticket" Foreground="White"  BorderBrush="Black" FontFamily="Times New Roman" FontSize="14" Click="MenuItem_Click" Background="{x:Null}">
            </MenuItem>
        </Menu>
        <TextBox HorizontalAlignment="Center" Margin="0,262,0,0" TextWrapping="Wrap" Text="Вы успешно вошли как Администратор" VerticalAlignment="Top" Width="660" Height="68" Background="{x:Null}" BorderBrush="Black" Foreground="White" FontSize="36"/>
        <Button Content="Manager" HorizontalAlignment="Left" Margin="602,449,0,0" VerticalAlignment="Top" Click="Button_Click"/>
        <Button Content="Trainer" HorizontalAlignment="Left" Margin="668,449,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.196,0.083" Click="Button_Click_1"/>
        <Button Content="Accountant" HorizontalAlignment="Left" Margin="713,449,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.179,-0.16" Click="Button_Click_2"/>
    </Grid>
</Window>
